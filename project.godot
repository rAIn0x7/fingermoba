; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but this is here for reference.

config_version=5

[application]

config/name="FingerMOBA"
config/features=PackedStringArray("4.3", "Mobile")
run/main_scene="res://scenes/main_menu.tscn"
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
GoldManager="*res://scripts/autoload/gold_manager.gd"
ShopController="*res://scripts/autoload/shop_controller.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=1

[input]

[physics]

2d/default_gravity=0.0

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.05, 0.12, 0.05, 1)
